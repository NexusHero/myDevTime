# PowerSync self-hosted service — copy to `.env` and fill in. Never commit `.env`.

# Our app Postgres, which PowerSync replicates FROM (needs logical replication).
PS_SOURCE_DATABASE_URI=postgres://user:pass@host:5432/mydevtime

# A SEPARATE Postgres database PowerSync uses for its own bucket/sync state.
PS_STORAGE_DATABASE_URI=postgres://user:pass@host:5432/powersync

# JWKS endpoint of our NestJS backend, used to validate device sync tokens.
PS_JWKS_URI=https://api.example.com/.well-known/jwks.json

# Host port to expose the sync service on.
PS_PORT=8080
