{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/canvas/**",
              "components/core/**",
              "components/forms/**",
              "components/instruments/**",
              "components/navigation/**",
              "ui_kits/devtime/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Clash Display|Space Grotesk|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Clash Display, Space Grotesk, Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIAskBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|scopes|answers|defaultAnswer|key|ref|className|style|children)$/]",
        "message": "<AIAskBar> doesn't accept that prop. Declared props: placeholder, scopes, answers, defaultAnswer."
      },
      {
        "selector": "JSXOpeningElement[name.name='AICallout'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|children|action|compact|key|ref|className|style|children)$/]",
        "message": "<AICallout> doesn't accept that prop. Declared props: title, children, action, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppShell'] > JSXAttribute > JSXIdentifier[name!=/^(?:posture|items|active|onNavigate|children|key|ref|className|style|children)$/]",
        "message": "<AppShell> doesn't accept that prop. Declared props: posture, items, active, onNavigate, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppShell'] > JSXAttribute[name.name='posture'] > Literal[value!=/^(?:sidebar|tabs)$/]",
        "message": "<AppShell> posture must be one of 'sidebar' | 'tabs'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|good|crit|warn)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'good' | 'crit' | 'warn'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BoxPlot'] > JSXAttribute > JSXIdentifier[name!=/^(?:min|q1|median|q3|max|target|lo|hi|width|color|key|ref|className|style|children)$/]",
        "message": "<BoxPlot> doesn't accept that prop. Declared props: min, q1, median, q3, max, target, lo, hi, width, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='BudgetRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:percent|size|color|key|ref|className|style|children)$/]",
        "message": "<BudgetRing> doesn't accept that prop. Declared props: percent, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|disabled|fullWidth|onClick|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, disabled, fullWidth, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|title|subtitle|action|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, title, subtitle, action, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckinCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:onDone|compact|key|ref|className|style|children)$/]",
        "message": "<CheckinCard> doesn't accept that prop. Declared props: onDone, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='DayBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|time|kind|color|height|onAccept|onDismiss|key|ref|className|style|children)$/]",
        "message": "<DayBlock> doesn't accept that prop. Declared props: label, time, kind, color, height, onAccept, onDismiss."
      },
      {
        "selector": "JSXOpeningElement[name.name='DayBlock'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:actual|ghost|meeting)$/]",
        "message": "<DayBlock> kind must be one of 'actual' | 'ghost' | 'meeting'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|hint|action|compact|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, hint, action, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='Heatmap'] > JSXAttribute > JSXIdentifier[name!=/^(?:weeks|data|color|key|ref|className|style|children)$/]",
        "message": "<Heatmap> doesn't accept that prop. Declared props: weeks, data, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|size|variant|active|onClick|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, label, size, variant, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|filled)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'filled'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|onChange|type|mono|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, placeholder, value, onChange, type, mono, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|number|time|date|email)$/]",
        "message": "<Input> type must be one of 'text' | 'number' | 'time' | 'date' | 'email'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IslandAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|onClick|key|ref|className|style|children)$/]",
        "message": "<IslandAction> doesn't accept that prop. Declared props: label, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='LeaveBalance'] > JSXAttribute > JSXIdentifier[name!=/^(?:entitlement|taken|planned|carryover|label|unit|key|ref|className|style|children)$/]",
        "message": "<LeaveBalance> doesn't accept that prop. Declared props: entitlement, taken, planned, carryover, label, unit."
      },
      {
        "selector": "JSXOpeningElement[name.name='LoadMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|label|width|key|ref|className|style|children)$/]",
        "message": "<LoadMeter> doesn't accept that prop. Declared props: score, label, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoodCheck'] > JSXAttribute > JSXIdentifier[name!=/^(?:onSelect|question|key|ref|className|style|children)$/]",
        "message": "<MoodCheck> doesn't accept that prop. Declared props: onSelect, question."
      },
      {
        "selector": "JSXOpeningElement[name.name='OvertimeGauge'] > JSXAttribute > JSXIdentifier[name!=/^(?:hours|max|key|ref|className|style|children)$/]",
        "message": "<OvertimeGauge> doesn't accept that prop. Declared props: hours, max."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|delta|mono|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: label, value, delta, mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='WeekSparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:values|color|width|height|key|ref|className|style|children)$/]",
        "message": "<WeekSparkline> doesn't accept that prop. Declared props: values, color, width, height."
      }
    ]
  },
