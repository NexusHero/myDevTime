# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
dist-pages/
*.tsbuildinfo

# Test / coverage
coverage/

# Env & local overrides (never commit secrets — SKILL §4)
.env
.env.*
!.env.example
*.local

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

