{
  "name": "mydevtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cross-platform time tracking (iOS + Android + Web) — TypeScript monorepo. See docs/architecture.md and ADR-0003/0014.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "build": "pnpm -r --if-present build",
    "check:docs": "node scripts/check-docs.mjs",
    "check:purity": "node scripts/check-domain-purity.mjs",
    "gate": "./test.sh",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.1",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.3"
    }
  }
}
