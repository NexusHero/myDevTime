{
  "name": "@mydevtime/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Node.js/TypeScript backend — modular monolith on Fastify (ADR-0003/0015).",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "openapi:emit": "tsx src/openapi.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^6.0.0",
    "@mydevtime/domain": "workspace:*",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.5.0",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^7.0.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "postgres": "^3.4.5",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "drizzle-kit": "^0.31.10",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.19.2"
  }
}
