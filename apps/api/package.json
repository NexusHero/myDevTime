{
  "name": "@mydevtime/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Node.js/TypeScript backend — NestJS on the Fastify adapter, module-per-domain (ADR-0025).",
  "scripts": {
    "dev": "pnpm run build && (tsc -p tsconfig.build.json --watch --preserveWatchOutput & node --watch dist/main.js)",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "openapi:emit": "pnpm run build && node dist/openapi.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.11",
    "@ai-sdk/google": "^4.0.12",
    "@ai-sdk/openai": "^4.0.11",
    "@mydevtime/domain": "workspace:*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "ai": "^7.0.20",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.5.0",
    "jose": "^6.1.0",
    "nestjs-zod": "^5.4.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.3.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@swc/core": "^1.15.43",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "drizzle-kit": "^0.31.10",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.19.2",
    "unplugin-swc": "^1.5.9"
  }
}
