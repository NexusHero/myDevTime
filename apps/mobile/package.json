{
  "name": "@mydevtime/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "myDevTime client — iOS + Android + Web from one Expo/React Native codebase (ADR-0004). Consumes @mydevtime/design.",
  "main": "expo-router/entry",
  "scripts": {
    "//": "The app consumes the built dist of the workspace packages, so build them first. prestart covers `pnpm start`; run `pnpm build:deps` before a direct `npx expo start`.",
    "build:deps": "pnpm --filter \"./packages/*\" build",
    "prestart": "pnpm run build:deps",
    "start": "expo start",
    "android": "pnpm run build:deps && expo start --android",
    "ios": "pnpm run build:deps && expo start --ios",
    "web": "pnpm run build:deps && expo start --web",
    "export:web": "pnpm run build:deps && expo export -p web",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@babel/core": "7.29.7",
    "@babel/runtime": "8.0.0",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "~4.0.1",
    "@mydevtime/design": "workspace:*",
    "@mydevtime/domain": "workspace:*",
    "@shopify/flash-list": "1.7.6",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.21",
    "expo-status-bar": "~2.0.0",
    "react-native-screens": "~4.4.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-reanimated": "~3.16.7",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-svg": "15.15.5",
    "react-native-web": "~0.19.13",
    "@tanstack/react-query": "^5.62.7",
    "expo-system-ui": "~4.0.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "~18.3.12",
    "typescript": "~5.6.3"
  }
}
