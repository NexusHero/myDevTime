{
  "name": "@mydevtime/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "myDevTime client — iOS + Android + Web from one Expo/React Native codebase (ADR-0004). Consumes @mydevtime/design.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@mydevtime/design": "workspace:*",
    "expo": "~52.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.6.3"
  }
}
