{
  "expo": {
    "name": "myDevTime",
    "slug": "mydevtime",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "mydevtime",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "../../../packages/design/assets/logo/icon.svg",
    "splash": {
      "image": "../../../packages/design/assets/logo/splash.svg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "../../../packages/design/assets/logo/icon.svg"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "../../../packages/design/assets/logo/icon.svg",
        "backgroundColor": "#ffffff"
      }
    },
    "web": { "bundler": "metro", "output": "single" }
  }
}
