{
  "name": "spike-client-rn-expo",
  "version": "0.0.0",
  "private": true,
  "description": "Throwaway spike (#1) — validates React Native + Expo for iOS/Android/Web (ADR-0004). NOT part of the pnpm workspace.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "verify:types": "tsc -p tsconfig.verify.json",
    "verify:test": "vitest run --config vitest.config.ts",
    "verify": "npm run verify:types && npm run verify:test"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-notifications": "~0.29.0",
    "expo-sqlite": "~15.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.6.3",
    "vitest": "^4.0.0"
  }
}
